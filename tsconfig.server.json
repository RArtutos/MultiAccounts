{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "outDir": "dist",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/server/**/*", "src/lib/**/*"],
  "exclude": ["src/components/**/*", "src/pages/**/*", "src/App.tsx", "src/main.tsx"]
}